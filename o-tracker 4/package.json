{
  "name": "o-tracker",
  "version": "0.1.0",
  "description": "Telegram bot + Gemini assistant + web dashboard for Oura Ring data (public, multilingual: ru/en/pt).",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "@prisma/client": "^6.2.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0",
    "@fastify/static": "^8.0.3",
    "@fastify/formbody": "^8.0.1",
    "grammy": "^1.34.0",
    "luxon": "^3.5.0",
    "node-cron": "^3.0.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "prisma": "^6.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
